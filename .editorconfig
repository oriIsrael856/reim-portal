# https://editorconfig.org — keeps editors aligned with .gitattributes (LF).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,cjs,mjs,ts,tsx,css,html,json,md,yml,yaml}]
indent_style = space
indent_size = 4

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
