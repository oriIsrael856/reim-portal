# Copy this file to:  functions/.env.reim-portal
# (Firebase loads .env.<PROJECT_ID> when you deploy to that project.)

# Required: team inbox that receives each signup notification
NEWSLETTER_TO_EMAIL=Ofere@matnasim.org.il
#
# Resend testing: with FROM=onboarding@resend.dev you may ONLY send TO your Resend
# account email until you verify a domain at https://resend.com/domains — then set
# NEWSLETTER_FROM_EMAIL to an address on that domain and you can use any TO.

# Resend "from" — use onboarding@resend.dev until you verify a domain in Resend
NEWSLETTER_FROM_EMAIL=onboarding@resend.dev

# Match Resend free tier (UTC). Lower these if you want a safety margin.
NEWSLETTER_DAILY_CAP=100
NEWSLETTER_MONTHLY_CAP=3000
